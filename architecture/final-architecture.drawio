<mxfile host="app.diagrams.net" modified="2026-05-20T00:00:00Z" agent="Codex" version="24.7.17" type="device"><diagram id="iris-architecture" name="IRIS Architecture"><mxGraphModel dx="1800" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2200" pageHeight="1450" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="outer" value="" style="rounded=1;whiteSpace=wrap;html=1;shadow=0;fillColor=#FFFFFF;strokeColor=#AEC3D6;strokeWidth=1.5;fontColor=#17324D;fontSize=18;fontStyle=1;align=left;verticalAlign=top;spacingTop=10;spacingLeft=12;" vertex="1" parent="1"><mxGeometry x="32" y="120" width="2136" height="1288" as="geometry"/></mxCell><mxCell id="panel-external" value="<b>External Sources</b><br/><font style=&quot;font-size:12px;color:#5B6E82;&quot;>Cedants, TPAs, watchlists, and business consumers</font>" style="rounded=1;whiteSpace=wrap;html=1;shadow=0;fillColor=#FFFFFF;strokeColor=#CAD6E3;strokeWidth=1.5;fontColor=#17324D;fontSize=22;fontStyle=1;align=left;verticalAlign=top;spacingTop=10;spacingLeft=12;" vertex="1" parent="1"><mxGeometry x="60" y="170" width="300" height="1050" as="geometry"/></mxCell><mxCell id="panel-presentation" value="<b>Presentation Layer</b><br/><font style=&quot;font-size:12px;color:#5B6E82;&quot;>Role-aware React workspace, approvals, dashboards, and operational review</font>" style="rounded=1;whiteSpace=wrap;html=1;shadow=0;fillColor=#FFFFFF;strokeColor=#CAD6E3;strokeWidth=1.5;fontColor=#17324D;fontSize=22;fontStyle=1;align=left;verticalAlign=top;spacingTop=10;spacingLeft=12;" vertex="1" parent="1"><mxGeometry x="390" y="170" width="1730" height="160" as="geometry"/></mxCell><mxCell id="panel-application" value="<b>API / Service Core</b><br/><font style=&quot;font-size:12px;color:#5B6E82;&quot;>FastAPI routers, service layer, repositories, auth, and execution controls</font>" style="rounded=1;whiteSpace=wrap;html=1;shadow=0;fillColor=#FFFFFF;strokeColor=#CAD6E3;strokeWidth=1.5;fontColor=#17324D;fontSize=22;fontStyle=1;align=left;verticalAlign=top;spacingTop=10;spacingLeft=12;" vertex="1" parent="1"><mxGeometry x="390" y="350" width="1170" height="250" as="geometry"/></mxCell><mxCell id="panel-workflow" value="<b>Workflow Orchestration</b><br/><font style=&quot;font-size:12px;color:#5B6E82;&quot;>Implemented cession, settlement, screening, approval, and reporting pipeline</font>" style="rounded=1;whiteSpace=wrap;html=1;shadow=0;fillColor=#FFFFFF;strokeColor=#CAD6E3;strokeWidth=1.5;fontColor=#17324D;fontSize=22;fontStyle=1;align=left;verticalAlign=top;spacingTop=10;spacingLeft=12;" vertex="1" parent="1"><mxGeometry x="390" y="630" width="1180" height="390" as="geometry"/></mxCell><mxCell id="panel-ai" value="<b>AI Assistance</b><br/><font style=&quot;font-size:12px;color:#5B6E82;&quot;>OpenAI-assisted verification, SQL planning, and HITL governance</font>" style="rounded=1;whiteSpace=wrap;html=1;shadow=0;fillColor=#FFFFFF;strokeColor=#CAD6E3;strokeWidth=1.5;fontColor=#17324D;fontSize=22;fontStyle=1;align=left;verticalAlign=top;spacingTop=10;spacingLeft=12;" vertex="1" parent="1"><mxGeometry x="1590" y="350" width="530" height="280" as="geometry"/></mxCell><mxCell id="panel-data" value="<b>Data and Storage</b><br/><font style=&quot;font-size:12px;color:#5B6E82;&quot;>Relational persistence, JSON workflow state, workbook cache, and generated artifacts</font>" style="rounded=1;whiteSpace=wrap;html=1;shadow=0;fillColor=#FFFFFF;strokeColor=#CAD6E3;strokeWidth=1.5;fontColor=#17324D;fontSize=22;fontStyle=1;align=left;verticalAlign=top;spacingTop=10;spacingLeft=12;" vertex="1" parent="1"><mxGeometry x="1590" y="650" width="530" height="370" as="geometry"/></mxCell><mxCell id="panel-governance" value="<b>Governance / Runtime</b><br/><font style=&quot;font-size:12px;color:#5B6E82;&quot;>Logging, audit, security, approvals, and delivery realities in the repo</font>" style="rounded=1;whiteSpace=wrap;html=1;shadow=0;fillColor=#FFFFFF;strokeColor=#CAD6E3;strokeWidth=1.5;fontColor=#17324D;fontSize=22;fontStyle=1;align=left;verticalAlign=top;spacingTop=10;spacingLeft=12;" vertex="1" parent="1"><mxGeometry x="390" y="1040" width="1730" height="190" as="geometry"/></mxCell><mxCell id="actors" value="<b>Internal teams</b><br/><font style=&quot;font-size:12px;color:#5B6E82;&quot;>Claims Ops, Underwriting, Compliance, Admin<br/>Actuarial, Finance, Cedant Relationship users<br/>Human review, approvals, overrides, case routing</font>" style="rounded=1;whiteSpace=wrap;html=1;shadow=0;fillColor=#F6F9FC;strokeColor=#24496E;strokeWidth=1.5;fontColor=#17324D;fontSize=18;fontStyle=1;align=left;verticalAlign=top;spacingTop=10;spacingLeft=12;" vertex="1" parent="1"><mxGeometry x="85" y="220" width="250" height="165" as="geometry"/></mxCell><mxCell id="sources" value="<b>Cedant and TPA inbound files</b><br/><font style=&quot;font-size:12px;color:#5B6E82;&quot;>Pension Status, Settlement, Fixed Leg<br/>Mortality Report, Spouse Events, Activity Report<br/>Fee Schedule, CSV / XLSX / tab CSV / pipe TXT<br/>Routed through Claims cession upload + testcases</font>" style="rounded=1;whiteSpace=wrap;html=1;shadow=0;fillColor=#EAF1FF;strokeColor=#3A77F2;strokeWidth=1.5;fontColor=#17324D;fontSize=18;fontStyle=1;align=left;verticalAlign=top;spacingTop=10;spacingLeft=12;" vertex="1" parent="1"><mxGeometry x="85" y="410" width="250" height="300" as="geometry"/></mxCell><mxCell id="watchlists" value="<b>Screening sources</b><br/><font style=&quot;font-size:12px;color:#5B6E82;&quot;>OFAC and FinCEN cache workbooks<br/>Editable screening workbook exports (.xlsx)<br/>Ad-hoc and cession_file sanctions cases</font>" style="rounded=1;whiteSpace=wrap;html=1;shadow=0;fillColor=#FDF4E1;strokeColor=#D79A2B;strokeWidth=1.5;fontColor=#17324D;fontSize=18;fontStyle=1;align=left;verticalAlign=top;spacingTop=10;spacingLeft=12;" vertex="1" parent="1"><mxGeometry x="85" y="735" width="250" height="180" as="geometry"/></mxCell><mxCell id="consumers" value="<b>Downstream consumers</b><br/><font style=&quot;font-size:12px;color:#5B6E82;&quot;>Settlement reviewers and compliance analysts<br/>Reports catalog users across Operations, Finance, Legal<br/>Contract and cedant detail workspaces<br/>IRiS Assist readers of operational and financial data</font>" style="rounded=1;whiteSpace=wrap;html=1;shadow=0;fillColor=#EAF7F1;strokeColor=#2F9365;strokeWidth=1.5;fontColor=#17324D;fontSize=18;fontStyle=1;align=left;verticalAlign=top;spacingTop=10;spacingLeft=12;" vertex="1" parent="1"><mxGeometry x="85" y="940" width="250" height="255" as="geometry"/></mxCell><mxCell id="spa" value="<b>React 19 + TypeScript + Vite SPA</b><br/><font style=&quot;font-size:12px;color:#5B6E82;&quot;>TanStack Query, Axios, Zustand, React Router, Recharts, Lucide, role-based navigation, dashboard, worklist, underwriting, claims, operations, compliance, reports, admin, and IRiS Assist drawer</font>" style="rounded=1;whiteSpace=wrap;html=1;shadow=0;fillColor=#EAF1FF;strokeColor=#3A77F2;strokeWidth=1.5;fontColor=#17324D;fontSize=18;fontStyle=1;align=left;verticalAlign=top;spacingTop=10;spacingLeft=12;" vertex="1" parent="1"><mxGeometry x="430" y="210" width="1280" height="90" as="geometry"/></mxCell><mxCell id="oversight" value="<b>Human oversight surfaces</b><br/><font style=&quot;font-size:12px;color:#5B6E82;&quot;>Worklist queues, sanctions case review, settlement approve/hold/dispute, admin workflow-agent controls, toast/status feedback</font>" style="rounded=1;whiteSpace=wrap;html=1;shadow=0;fillColor=#FCEAEA;strokeColor=#D86D68;strokeWidth=1.5;fontColor=#17324D;fontSize=18;fontStyle=1;align=left;verticalAlign=top;spacingTop=10;spacingLeft=12;" vertex="1" parent="1"><mxGeometry x="1730" y="210" width="350" height="90" as="geometry"/></mxCell><mxCell id="routers" value="<b>FastAPI /iris/api/v1 routers</b><br/><font style=&quot;font-size:12px;color:#5B6E82;&quot;>auth, dashboard, underwriting, claims, operations<br/>compliance, audit, reports, admin, chatbot, worklist</font>" style="rounded=1;whiteSpace=wrap;html=1;shadow=0;fillColor=#ECF3F8;strokeColor=#24496E;strokeWidth=1.5;fontColor=#17324D;fontSize=18;fontStyle=1;align=left;verticalAlign=top;spacingTop=10;spacingLeft=12;" vertex="1" parent="1"><mxGeometry x="430" y="395" width="350" height="155" as="geometry"/></mxCell><mxCell id="services" value="<b>Service orchestration</b><br/><font style=&quot;font-size:12px;color:#5B6E82;&quot;>ClaimsService, OperationsService, UnderwritingService<br/>ComplianceService, ReportsService, AuditService<br/>AdminService, WorklistService, DashboardService, ChatbotService</font>" style="rounded=1;whiteSpace=wrap;html=1;shadow=0;fillColor=#E7F7F8;strokeColor=#1D9AA8;strokeWidth=1.5;fontColor=#17324D;fontSize=18;fontStyle=1;align=left;verticalAlign=top;spacingTop=10;spacingLeft=12;" vertex="1" parent="1"><mxGeometry x="805" y="395" width="380" height="155" as="geometry"/></mxCell><mxCell id="controls" value="<b>Execution controls</b><br/><font style=&quot;font-size:12px;color:#5B6E82;&quot;>JWT auth, bcrypt/passlib, role gating, X-Active-Role switching<br/>SQLAlchemy repositories, schema validation, structured errors, CORS</font>" style="rounded=1;whiteSpace=wrap;html=1;shadow=0;fillColor=#F2EDFF;strokeColor=#8A6BE8;strokeWidth=1.5;fontColor=#17324D;fontSize=18;fontStyle=1;align=left;verticalAlign=top;spacingTop=10;spacingLeft=12;" vertex="1" parent="1"><mxGeometry x="1210" y="395" width="310" height="155" as="geometry"/></mxCell><mxCell id="openai" value="<b>OpenAI Responses API</b><br/><font style=&quot;font-size:12px;color:#5B6E82;&quot;>OPENAI_MODEL defaults to gpt-5.2 in repo config</font>" style="rounded=1;whiteSpace=wrap;html=1;shadow=0;fillColor=#F2EDFF;strokeColor=#8A6BE8;strokeWidth=1.5;fontColor=#17324D;fontSize=18;fontStyle=1;align=left;verticalAlign=top;spacingTop=10;spacingLeft=12;" vertex="1" parent="1"><mxGeometry x="1630" y="395" width="225" height="90" as="geometry"/></mxCell><mxCell id="screening_ai" value="<b>Compliance verification</b><br/><font style=&quot;font-size:12px;color:#5B6E82;&quot;>Cache match -&gt; model reasoning -&gt; clear, pending review, or escalate</font>" style="rounded=1;whiteSpace=wrap;html=1;shadow=0;fillColor=#FDF4E1;strokeColor=#D79A2B;strokeWidth=1.5;fontColor=#17324D;fontSize=18;fontStyle=1;align=left;verticalAlign=top;spacingTop=10;spacingLeft=12;" vertex="1" parent="1"><mxGeometry x="1875" y="395" width="225" height="90" as="geometry"/></mxCell><mxCell id="chatbot_ai" value="<b>IRiS Assist SQL path</b><br/><font style=&quot;font-size:12px;color:#5B6E82;&quot;>Read-only SQL plan, execute, repair once, answer from live DB context</font>" style="rounded=1;whiteSpace=wrap;html=1;shadow=0;fillColor=#EAF1FF;strokeColor=#3A77F2;strokeWidth=1.5;fontColor=#17324D;fontSize=18;fontStyle=1;align=left;verticalAlign=top;spacingTop=10;spacingLeft=12;" vertex="1" parent="1"><mxGeometry x="1630" y="505" width="225" height="90" as="geometry"/></mxCell><mxCell id="workflow_cfg" value="<b>Workflow agent controls</b><br/><font style=&quot;font-size:12px;color:#5B6E82;&quot;>thresholds, retry limits, fallback mode, always_pause_for_hitl, pause behavior</font>" style="rounded=1;whiteSpace=wrap;html=1;shadow=0;fillColor=#FCEAEA;strokeColor=#D86D68;strokeWidth=1.5;fontColor=#17324D;fontSize=18;fontStyle=1;align=left;verticalAlign=top;spacingTop=10;spacingLeft=12;" vertex="1" parent="1"><mxGeometry x="1875" y="505" width="225" height="90" as="geometry"/></mxCell><mxCell id="db" value="<b>SQLAlchemy relational core</b><br/><font style=&quot;font-size:12px;color:#5B6E82;&quot;>SQLite is the default runtime in this repo; DATABASE_URL supports PostgreSQL<br/>users, cedents, contracts, policy_register, cession_files, records, exceptions, settlements, worklist_items, screening_events, reports, audit_events, reference_data_versions, screening_cache_lists</font>" style="rounded=1;whiteSpace=wrap;html=1;shadow=0;fillColor=#EAF7F1;strokeColor=#2F9365;strokeWidth=1.5;fontColor=#17324D;fontSize=18;fontStyle=1;align=left;verticalAlign=top;spacingTop=10;spacingLeft=12;" vertex="1" parent="1"><mxGeometry x="1630" y="710" width="450" height="110" as="geometry"/></mxCell><mxCell id="json_state" value="<b>JSON workflow state</b><br/><font style=&quot;font-size:12px;color:#5B6E82;&quot;>cession_pipeline_overrides.json<br/>settlement_overrides.json<br/>operations_pipeline_overrides.json<br/>admin_state.json and detail overlay stores</font>" style="rounded=1;whiteSpace=wrap;html=1;shadow=0;fillColor=#FDF4E1;strokeColor=#D79A2B;strokeWidth=1.5;fontColor=#17324D;fontSize=18;fontStyle=1;align=left;verticalAlign=top;spacingTop=10;spacingLeft=12;" vertex="1" parent="1"><mxGeometry x="1630" y="840" width="215" height="145" as="geometry"/></mxCell><mxCell id="files_store" value="<b>Filesystem artifacts</b><br/><font style=&quot;font-size:12px;color:#5B6E82;&quot;>generated_reports/settlements/<br/>Cash Settlements Tracker + GRDR load form<br/>settlement_report_artifacts.json<br/>backend/testcases and workbook downloads</font>" style="rounded=1;whiteSpace=wrap;html=1;shadow=0;fillColor=#EAF1FF;strokeColor=#3A77F2;strokeWidth=1.5;fontColor=#17324D;fontSize=18;fontStyle=1;align=left;verticalAlign=top;spacingTop=10;spacingLeft=12;" vertex="1" parent="1"><mxGeometry x="1865" y="840" width="215" height="145" as="geometry"/></mxCell><mxCell id="log_box" value="<b>Structured logging and audit</b><br/><font style=&quot;font-size:12px;color:#5B6E82;&quot;>logger.info / debug / error across services, audit_events persistence, seeded + synthesized audit history, exportable audit reports</font>" style="rounded=1;whiteSpace=wrap;html=1;shadow=0;fillColor=#ECF3F8;strokeColor=#24496E;strokeWidth=1.5;fontColor=#17324D;fontSize=18;fontStyle=1;align=left;verticalAlign=top;spacingTop=10;spacingLeft=12;" vertex="1" parent="1"><mxGeometry x="430" y="1085" width="360" height="110" as="geometry"/></mxCell><mxCell id="sec_box" value="<b>Security and compliance controls</b><br/><font style=&quot;font-size:12px;color:#5B6E82;&quot;>JWT session auth, password hashing, role-aware APIs, super-admin impersonation header, sanctions case disposition workflow, chatbot guardrails for PII and off-topic prompts</font>" style="rounded=1;whiteSpace=wrap;html=1;shadow=0;fillColor=#F2EDFF;strokeColor=#8A6BE8;strokeWidth=1.5;fontColor=#17324D;fontSize=18;fontStyle=1;align=left;verticalAlign=top;spacingTop=10;spacingLeft=12;" vertex="1" parent="1"><mxGeometry x="810" y="1085" width="380" height="110" as="geometry"/></mxCell><mxCell id="approval_box" value="<b>Approvals and work routing</b><br/><font style=&quot;font-size:12px;color:#5B6E82;&quot;>Settlement Pending worklist items, sanctions review assignments, manual overrides, SLA-aware queues, approve/hold/dispute actions, dashboard and worklist visibility</font>" style="rounded=1;whiteSpace=wrap;html=1;shadow=0;fillColor=#FCEAEA;strokeColor=#D86D68;strokeWidth=1.5;fontColor=#17324D;fontSize=18;fontStyle=1;align=left;verticalAlign=top;spacingTop=10;spacingLeft=12;" vertex="1" parent="1"><mxGeometry x="1210" y="1085" width="370" height="110" as="geometry"/></mxCell><mxCell id="runtime_box" value="<b>Runtime reality in the repository</b><br/><font style=&quot;font-size:12px;color:#5B6E82;&quot;>FastAPI BackgroundTasks + frontend polling drive async progress. No Redis, Celery, Kafka, WebSockets, Docker, Kubernetes, or IaC manifests were detected. Frontend config targets a CloudFront-hosted /iris path in deployed environments.</font>" style="rounded=1;whiteSpace=wrap;html=1;shadow=0;fillColor=#F6F9FC;strokeColor=#1D9AA8;strokeWidth=1.5;fontColor=#17324D;fontSize=18;fontStyle=1;align=left;verticalAlign=top;spacingTop=10;spacingLeft=12;" vertex="1" parent="1"><mxGeometry x="1600" y="1085" width="480" height="110" as="geometry"/></mxCell><mxCell id="agents_map" value="<b>Workflow agent map</b><br/><font style=&quot;font-size:12px;color:#5B6E82;&quot;>Agent steps: Detect &amp; Map, Anomaly Detection, Resolution, Sanction Screening, File Generation | System steps: Clauses, Process, Summary, Worklist, Audit</font>" style="rounded=1;whiteSpace=wrap;html=1;shadow=0;fillColor=#F2EDFF;strokeColor=#8A6BE8;strokeWidth=1.5;fontColor=#17324D;fontSize=18;fontStyle=1;align=left;verticalAlign=top;spacingTop=10;spacingLeft=12;" vertex="1" parent="1"><mxGeometry x="445" y="925" width="650" height="70" as="geometry"/></mxCell><mxCell id="ops_view" value="<b>Operations V2 workspace</b><br/><font style=&quot;font-size:12px;color:#5B6E82;&quot;>Normalization -&gt; Calculations -&gt; Variance -&gt; Screening -&gt; AI Decision -&gt; Outcome, with outcome actions bridged into settlement approve/hold/reject paths</font>" style="rounded=1;whiteSpace=wrap;html=1;shadow=0;fillColor=#E7F7F8;strokeColor=#1D9AA8;strokeWidth=1.5;fontColor=#17324D;fontSize=18;fontStyle=1;align=left;verticalAlign=top;spacingTop=10;spacingLeft=12;" vertex="1" parent="1"><mxGeometry x="1115" y="925" width="415" height="70" as="geometry"/></mxCell><mxCell id="step1" value="<b>1. File upload</b><br/><font style=&quot;font-size:12px;color:#5B6E82;&quot;>Cedant/TPA files enter the claims pipeline</font>" style="rounded=1;whiteSpace=wrap;html=1;shadow=0;fillColor=#EAF1FF;strokeColor=#3A77F2;strokeWidth=1.5;fontColor=#17324D;fontSize=16;fontStyle=1;align=left;verticalAlign=top;spacingTop=10;spacingLeft=12;" vertex="1" parent="1"><mxGeometry x="445" y="700" width="155" height="80" as="geometry"/></mxCell><mxCell id="step2" value="<b>2. Detect &amp; map</b><br/><font style=&quot;font-size:12px;color:#5B6E82;&quot;>Identify file type, cedent, contract, and period</font>" style="rounded=1;whiteSpace=wrap;html=1;shadow=0;fillColor=#EAF1FF;strokeColor=#3A77F2;strokeWidth=1.5;fontColor=#17324D;fontSize=16;fontStyle=1;align=left;verticalAlign=top;spacingTop=10;spacingLeft=12;" vertex="1" parent="1"><mxGeometry x="615" y="700" width="155" height="80" as="geometry"/></mxCell><mxCell id="step3" value="<b>3. Validate + clauses</b><br/><font style=&quot;font-size:12px;color:#5B6E82;&quot;>pandas checks plus treaty clause retrieval</font>" style="rounded=1;whiteSpace=wrap;html=1;shadow=0;fillColor=#ECF3F8;strokeColor=#24496E;strokeWidth=1.5;fontColor=#17324D;fontSize=16;fontStyle=1;align=left;verticalAlign=top;spacingTop=10;spacingLeft=12;" vertex="1" parent="1"><mxGeometry x="785" y="700" width="155" height="80" as="geometry"/></mxCell><mxCell id="step4" value="<b>4. Adjudicate</b><br/><font style=&quot;font-size:12px;color:#5B6E82;&quot;>Anomalies, resolutions, overrides, and exceptions</font>" style="rounded=1;whiteSpace=wrap;html=1;shadow=0;fillColor=#FCEAEA;strokeColor=#D86D68;strokeWidth=1.5;fontColor=#17324D;fontSize=16;fontStyle=1;align=left;verticalAlign=top;spacingTop=10;spacingLeft=12;" vertex="1" parent="1"><mxGeometry x="955" y="700" width="155" height="80" as="geometry"/></mxCell><mxCell id="step5" value="<b>5. Compliance screen</b><br/><font style=&quot;font-size:12px;color:#5B6E82;&quot;>OFAC / FinCEN cache and OpenAI reasoning</font>" style="rounded=1;whiteSpace=wrap;html=1;shadow=0;fillColor=#FDF4E1;strokeColor=#D79A2B;strokeWidth=1.5;fontColor=#17324D;fontSize=16;fontStyle=1;align=left;verticalAlign=top;spacingTop=10;spacingLeft=12;" vertex="1" parent="1"><mxGeometry x="1125" y="700" width="155" height="80" as="geometry"/></mxCell><mxCell id="step6" value="<b>6. Delta detect</b><br/><font style=&quot;font-size:12px;color:#5B6E82;&quot;>Variance and exact-match reconciliation checks</font>" style="rounded=1;whiteSpace=wrap;html=1;shadow=0;fillColor=#EAF7F1;strokeColor=#2F9365;strokeWidth=1.5;fontColor=#17324D;fontSize=16;fontStyle=1;align=left;verticalAlign=top;spacingTop=10;spacingLeft=12;" vertex="1" parent="1"><mxGeometry x="1295" y="700" width="155" height="80" as="geometry"/></mxCell><mxCell id="step7" value="<b>7. Settlement calc</b><br/><font style=&quot;font-size:12px;color:#5B6E82;&quot;>Fixed leg, floating leg, fee, interest, net</font>" style="rounded=1;whiteSpace=wrap;html=1;shadow=0;fillColor=#EAF7F1;strokeColor=#2F9365;strokeWidth=1.5;fontColor=#17324D;fontSize=16;fontStyle=1;align=left;verticalAlign=top;spacingTop=10;spacingLeft=12;" vertex="1" parent="1"><mxGeometry x="485" y="825" width="175" height="80" as="geometry"/></mxCell><mxCell id="step8" value="<b>8. BEL / A-E outputs</b><br/><font style=&quot;font-size:12px;color:#5B6E82;&quot;>Calculation views, summary, and financial impact</font>" style="rounded=1;whiteSpace=wrap;html=1;shadow=0;fillColor=#E7F7F8;strokeColor=#1D9AA8;strokeWidth=1.5;fontColor=#17324D;fontSize=16;fontStyle=1;align=left;verticalAlign=top;spacingTop=10;spacingLeft=12;" vertex="1" parent="1"><mxGeometry x="680" y="825" width="175" height="80" as="geometry"/></mxCell><mxCell id="step9" value="<b>9. Reports + files</b><br/><font style=&quot;font-size:12px;color:#5B6E82;&quot;>CSV artifacts, report catalog entries, downloads</font>" style="rounded=1;whiteSpace=wrap;html=1;shadow=0;fillColor=#E7F7F8;strokeColor=#1D9AA8;strokeWidth=1.5;fontColor=#17324D;fontSize=16;fontStyle=1;align=left;verticalAlign=top;spacingTop=10;spacingLeft=12;" vertex="1" parent="1"><mxGeometry x="875" y="825" width="175" height="80" as="geometry"/></mxCell><mxCell id="step10" value="<b>10. Audit + worklist</b><br/><font style=&quot;font-size:12px;color:#5B6E82;&quot;>audit_events and routed approval tasks</font>" style="rounded=1;whiteSpace=wrap;html=1;shadow=0;fillColor=#ECF3F8;strokeColor=#24496E;strokeWidth=1.5;fontColor=#17324D;fontSize=16;fontStyle=1;align=left;verticalAlign=top;spacingTop=10;spacingLeft=12;" vertex="1" parent="1"><mxGeometry x="1070" y="825" width="175" height="80" as="geometry"/></mxCell><mxCell id="step11" value="<b>11. Human approval</b><br/><font style=&quot;font-size:12px;color:#5B6E82;&quot;>Approve/hold/dispute and UI notifications</font>" style="rounded=1;whiteSpace=wrap;html=1;shadow=0;fillColor=#FCEAEA;strokeColor=#D86D68;strokeWidth=1.5;fontColor=#17324D;fontSize=16;fontStyle=